{
  "version": 2,
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/index.cjs",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
