{
  "version": 2,
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/auth/partners", "destination": "/api/auth/partners.ts" },
    { "source": "/api/auth/branches", "destination": "/api/auth/branches.ts" },
    { "source": "/api/auth/login", "destination": "/api/auth/login.ts" },
    { "source": "/api/auth/me", "destination": "/api/auth/me.ts" },
    { "source": "/api/auth/logout", "destination": "/api/auth/logout.ts" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
